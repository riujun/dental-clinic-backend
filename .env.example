# Copiar a .env y completar. Ver README.md raíz para el detalle de cada variable.
NODE_ENV=development
PORT=4000

# MongoDB — 3 opciones:
#  a) Mongo de desarrollo efímero (recomendado sin setup): `npm run dev:mongo` en otra
#     terminal y usar mongodb://127.0.0.1:27018/dental-clinic (datos NO persisten)
#  b) Mongo local propio: mongodb://user:pass@localhost:27017/dental-clinic?authSource=admin
#  c) Atlas M0 gratuito: mongodb+srv://user:pass@cluster.mongodb.net/dental-clinic
MONGODB_URI=mongodb://127.0.0.1:27018/dental-clinic

# Auth — OBLIGATORIO (mínimo 32 caracteres; generar uno aleatorio para producción)
JWT_SECRET=cambia-este-secreto-de-desarrollo-por-uno-aleatorio-largo
JWT_EXPIRES_IN=1d

# Seed del primer super_admin de la plataforma (solo se crea si no existe ninguno)
SUPER_ADMIN_EMAIL=admin@plataforma.local
SUPER_ADMIN_PASSWORD=superadmin123

# URL del frontend permitida por CORS
CORS_ORIGIN=http://localhost:3000
